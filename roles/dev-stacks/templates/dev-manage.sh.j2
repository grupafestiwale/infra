#!/bin/bash
# {{ ansible_managed }}
# Dev Stack Manager - Grupa Festiwale
#
# Usage:
#   ./dev-manage.sh up coding       # Start coding stack
#   ./dev-manage.sh down crm        # Stop CRM stack
#   ./dev-manage.sh status          # Show all stacks status
#   ./dev-manage.sh up all          # Start everything (RAM warning!)
#   ./dev-manage.sh logs deerflow   # Follow logs for specific container

set -e

DEV_DIR="/opt/dev"
ENV_FILE="${DEV_DIR}/.env"
STACKS=("coding" "crm" "agentic" "browser" "n8n-dev")

# RAM budget per stack
declare -A RAM_USAGE
RAM_USAGE[coding]="~8 GB (OpenHands 2G + Bolt 1G + Tabby 4G)"
RAM_USAGE[crm]="~5 GB (Bitrix24 2G + MySQL 1G + Odoo 2G)"
RAM_USAGE[agentic]="~6 GB (DeerFlow 2G + Hermes 1G + CrewAI 1G + OpenViking 2G)"
RAM_USAGE[browser]="~512 MB (Lightpanda)"
RAM_USAGE[n8n-dev]="~1 GB (N8N Dev)"

RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
NC='\033[0m'

show_status() {
    echo -e "\n${YELLOW}=== VM-05 DEV Stack Status ===${NC}\n"
    echo -e "Total RAM available: 20 GB"
    echo -e "System + Traefik:    ~3 GB"
    echo -e "Available for stacks: ~17 GB\n"

    for stack in "${STACKS[@]}"; do
        local dir="${DEV_DIR}/${stack}"
        if [ -f "${dir}/docker-compose.yml" ]; then
            local running=$(cd "$dir" && docker compose ps --status running -q 2>/dev/null | wc -l)
            local total=$(cd "$dir" && docker compose ps -q 2>/dev/null | wc -l)
            if [ "$running" -gt 0 ]; then
                echo -e "  ${GREEN}[UP]${NC}   ${stack} (${running}/${total} containers) — RAM: ${RAM_USAGE[$stack]}"
            else
                echo -e "  ${RED}[DOWN]${NC} ${stack} — RAM: ${RAM_USAGE[$stack]}"
            fi
        fi
    done

    echo -e "\n${YELLOW}Current RAM usage:${NC}"
    free -h | head -2
    echo ""
}

stack_up() {
    local stack=$1
    if [ "$stack" = "all" ]; then
        echo -e "${RED}WARNING: Starting all stacks needs ~20.5 GB RAM!${NC}"
        echo -e "VM-05 has 20 GB. This will OOM. Start stacks selectively."
        echo -e "\nRecommended combo (fits in 17 GB):"
        echo -e "  ./dev-manage.sh up coding    # 8 GB"
        echo -e "  ./dev-manage.sh up agentic   # 6 GB"
        echo -e "  ./dev-manage.sh up browser   # 0.5 GB"
        echo -e "  TOTAL: ~14.5 GB — OK\n"
        read -p "Start ALL anyway? (y/N) " -n 1 -r
        echo
        if [[ ! $REPLY =~ ^[Yy]$ ]]; then
            exit 0
        fi
        for s in "${STACKS[@]}"; do
            stack_up "$s"
        done
        return
    fi

    local dir="${DEV_DIR}/${stack}"
    if [ ! -f "${dir}/docker-compose.yml" ]; then
        echo -e "${RED}Stack '${stack}' not found${NC}"
        echo "Available: ${STACKS[*]}"
        exit 1
    fi

    echo -e "${GREEN}Starting ${stack}...${NC} (RAM: ${RAM_USAGE[$stack]})"
    cd "$dir" && docker compose --env-file "$ENV_FILE" up -d
    echo -e "${GREEN}Done.${NC}\n"

    # Show URLs
    cd "$dir" && docker compose ps --format "table {%raw%}{{.Name}}\t{{.Status}}\t{{.Ports}}{%endraw%}" 2>/dev/null
}

stack_down() {
    local stack=$1
    if [ "$stack" = "all" ]; then
        for s in "${STACKS[@]}"; do
            stack_down "$s"
        done
        return
    fi

    local dir="${DEV_DIR}/${stack}"
    echo -e "${YELLOW}Stopping ${stack}...${NC}"
    cd "$dir" && docker compose down
    echo -e "${GREEN}Done.${NC}"
}

case "${1}" in
    up)
        stack_up "${2:-all}"
        ;;
    down)
        stack_down "${2:-all}"
        ;;
    status)
        show_status
        ;;
    logs)
        docker logs -f "${2}" 2>/dev/null || echo "Container '${2}' not found"
        ;;
    restart)
        stack_down "${2}"
        stack_up "${2}"
        ;;
    *)
        echo "Usage: $0 {up|down|restart|status|logs} [stack|container]"
        echo ""
        echo "Stacks: ${STACKS[*]}"
        echo ""
        echo "Examples:"
        echo "  $0 up coding        Start coding tools"
        echo "  $0 down crm         Stop CRM tools"
        echo "  $0 status           Show all stacks"
        echo "  $0 logs deerflow    Follow DeerFlow logs"
        echo "  $0 restart agentic  Restart agentic stack"
        ;;
esac
