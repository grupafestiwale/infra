# {{ ansible_managed }}
# DEV STACK: Coding Tools
# Usage: cd /opt/dev/coding && docker compose up -d
# RAM: ~8 GB total

services:
  # === OpenHands (formerly OpenDevin) ===
  # Autonomous AI software engineer
  # UI: openhands.dev.{{ domain }}
  openhands:
    image: ghcr.io/all-hands-ai/openhands:latest
    container_name: openhands
    restart: unless-stopped
    environment:
      WORKSPACE_BASE: /opt/workspace
      LLM_API_KEY: "${ANTHROPIC_API_KEY}"
      LLM_MODEL: "anthropic/claude-sonnet-4-20250514"
      LLM_BASE_URL: "${LITELLM_URL}"
      SANDBOX_TYPE: docker
    volumes:
      - /opt/dev/coding/openhands-workspace:/opt/workspace
      - /var/run/docker.sock:/var/run/docker.sock
    ports:
      - "3010:3000"
    networks:
      - dev-frontend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.openhands.rule=Host(`openhands.dev.{{ domain }}`)"
      - "traefik.http.services.openhands.loadbalancer.server.port=3000"
    deploy:
      resources:
        limits:
          memory: 2G

  # === Bolt.diy ===
  # Full-stack app generator in browser
  # UI: bolt.dev.{{ domain }}
  bolt:
    image: ghcr.io/stackblitz-labs/bolt.diy:latest
    container_name: bolt-diy
    restart: unless-stopped
    environment:
      OPENAI_API_KEY: "sk-litellm"
      OPENAI_API_BASE: "${LITELLM_URL}"
      DEFAULT_MODEL: "claude-sonnet"
    ports:
      - "3011:5173"
    networks:
      - dev-frontend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.bolt.rule=Host(`bolt.dev.{{ domain }}`)"
      - "traefik.http.services.bolt.loadbalancer.server.port=5173"
    deploy:
      resources:
        limits:
          memory: 1G

  # === Tabby ===
  # Self-hosted Copilot replacement (code completion + chat)
  # UI: tabby.dev.{{ domain }}
  tabby:
    image: tabbyml/tabby:latest
    container_name: tabby
    restart: unless-stopped
    command: serve --model StarCoder-1B --chat-model Qwen2-1.5B-Instruct
    volumes:
      - /opt/dev/coding/tabby-data:/data
    ports:
      - "3012:8080"
    networks:
      - dev-frontend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.tabby.rule=Host(`tabby.dev.{{ domain }}`)"
      - "traefik.http.services.tabby.loadbalancer.server.port=8080"
    deploy:
      resources:
        limits:
          memory: 4G

networks:
  dev-frontend:
    external: true
