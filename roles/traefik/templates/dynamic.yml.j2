# {{ ansible_managed }}
# Traefik Dynamic Configuration - Grupa Festiwale
# All apps protected by Authentik forward-auth (M365 SSO)

http:
  # === AUTHENTIK FORWARD AUTH MIDDLEWARE ===
  middlewares:
    authentik:
      forwardAuth:
        address: "http://{{ authentik_host }}:{{ authentik_outpost_port }}/outpost.goauthentik.io/auth/traefik"
        trustForwardHeader: true
        authResponseHeaders:
          - X-authentik-username
          - X-authentik-groups
          - X-authentik-email
          - X-authentik-name
          - X-authentik-uid

  routers:
    # === AUTHENTIK PORTAL (public - login page) ===
    auth:
      rule: "Host(`auth.{{ domain }}`)"
      entryPoints: [websecure]
      service: authentik
      tls:
        certResolver: cloudflare

    # === WEBHOOK BYPASS (no auth - external services call these) ===
    n8n-webhooks:
      rule: "Host(`n8n.{{ domain }}`) && (PathPrefix(`/webhook/`) || PathPrefix(`/webhook-test/`))"
      entryPoints: [websecure]
      service: n8n
      priority: 100
      tls:
        certResolver: cloudflare

    dify-api-public:
      rule: "Host(`dify.{{ domain }}`) && (PathPrefix(`/v1/`) || PathPrefix(`/files/`))"
      entryPoints: [websecure]
      service: dify-api-svc
      priority: 100
      tls:
        certResolver: cloudflare

    # === VM-04 AI PROD services (protected) ===
    n8n:
      rule: "Host(`n8n.{{ domain }}`)"
      entryPoints: [websecure]
      service: n8n
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

    dify:
      rule: "Host(`dify.{{ domain }}`)"
      entryPoints: [websecure]
      service: dify
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

    chat:
      rule: "Host(`chat.{{ domain }}`)"
      entryPoints: [websecure]
      service: lobechat
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

    ruflo:
      rule: "Host(`ruflo.{{ domain }}`)"
      entryPoints: [websecure]
      service: ruflo
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

    api:
      rule: "Host(`api.{{ domain }}`)"
      entryPoints: [websecure]
      service: litellm
      tls:
        certResolver: cloudflare
      # API endpoint - no forward auth (uses API key auth)

    # === BUSINESS APPS (protected) ===
    borys:
      rule: "Host(`borys.{{ domain }}`)"
      entryPoints: [websecure]
      service: borys
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

    rekrutacja:
      rule: "Host(`rekrutacja.{{ domain }}`)"
      entryPoints: [websecure]
      service: rekrutacja
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

    # === LXC-03 DATA services (protected) ===
    files:
      rule: "Host(`files.{{ domain }}`)"
      entryPoints: [websecure]
      service: nextcloud
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

    docs:
      rule: "Host(`docs.{{ domain }}`)"
      entryPoints: [websecure]
      service: paperless
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

    # === MONITORING (protected) ===
    grafana:
      rule: "Host(`grafana.{{ domain }}`)"
      entryPoints: [websecure]
      service: grafana
      middlewares: [authentik]
      tls:
        certResolver: cloudflare

  services:
    # Auth
    authentik:
      loadBalancer:
        servers:
          - url: "http://{{ authentik_host }}:{{ authentik_port }}"

    # AI & Tools
    n8n:
      loadBalancer:
        servers:
          - url: "http://10.10.40.5:5678"

    dify:
      loadBalancer:
        servers:
          - url: "http://10.10.40.5:3000"

    dify-api-svc:
      loadBalancer:
        servers:
          - url: "http://10.10.40.5:5001"

    lobechat:
      loadBalancer:
        servers:
          - url: "http://10.10.40.5:3210"

    litellm:
      loadBalancer:
        servers:
          - url: "http://10.10.40.5:4000"

    ruflo:
      loadBalancer:
        servers:
          - url: "http://10.10.40.5:3001"

    # Business Apps
    borys:
      loadBalancer:
        servers:
          - url: "http://10.10.40.5:3100"

    rekrutacja:
      loadBalancer:
        servers:
          - url: "http://10.10.40.5:3200"

    # Data
    nextcloud:
      loadBalancer:
        servers:
          - url: "http://10.10.30.4:8080"

    paperless:
      loadBalancer:
        servers:
          - url: "http://10.10.30.4:8000"

    # Monitoring
    grafana:
      loadBalancer:
        servers:
          - url: "http://10.10.10.2:{{ grafana_port }}"
