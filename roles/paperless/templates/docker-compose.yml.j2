# {{ ansible_managed }}
# Paperless-NGX - Document Management - Grupa Festiwale

services:
  paperless:
    image: ghcr.io/paperless-ngx/paperless-ngx:latest
    container_name: paperless
    restart: unless-stopped
    ports:
      - "8000:8000"
    environment:
      PAPERLESS_DBENGINE: postgresql
      PAPERLESS_DBHOST: "10.10.30.3"
      PAPERLESS_DBPORT: "{{ postgresql_port }}"
      PAPERLESS_DBNAME: paperless
      PAPERLESS_DBUSER: paperless
      PAPERLESS_DBPASS: "{{ vault_pg_paperless_password }}"
      PAPERLESS_REDIS: "redis://:{{ vault_dragonflydb_password }}@10.10.30.3:{{ dragonflydb_port }}"
      PAPERLESS_URL: "https://docs.{{ domain }}"
      PAPERLESS_SECRET_KEY: "{{ vault_pg_paperless_password | hash('sha256') }}"
      PAPERLESS_OCR_LANGUAGE: pol+eng
      PAPERLESS_TIME_ZONE: "{{ timezone }}"
      PAPERLESS_CONSUMER_POLLING: "30"
      PAPERLESS_TASK_WORKERS: 2
    volumes:
      - /opt/paperless/data:/usr/src/paperless/data
      - "{{ storagebox_paperless_path }}:/usr/src/paperless/media"
      - /opt/paperless/consume:/usr/src/paperless/consume
      - /opt/paperless/export:/usr/src/paperless/export
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:8000"]
      interval: 30s
      timeout: 10s
      retries: 5
