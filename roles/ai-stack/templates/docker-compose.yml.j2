# {{ ansible_managed }}
# AI Production Stack - VM-04 - Grupa Festiwale

services:
  # === LLM Layer ===
  ollama:
    image: ollama/ollama:latest
    container_name: ollama
    restart: unless-stopped
    volumes:
      - /opt/ai-stack/ollama:/root/.ollama
    networks:
      - backend
    deploy:
      resources:
        limits:
          cpus: "4"
          memory: 16G

  litellm:
    image: ghcr.io/berriai/litellm:main-latest
    container_name: litellm
    restart: unless-stopped
    command: ["--config", "/app/config.yml", "--port", "4000"]
    volumes:
      - /opt/ai-stack/litellm/config.yml:/app/config.yml:ro
    networks:
      - frontend
      - backend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.litellm.rule=Host(`api.{{ domain }}`)"
      - "traefik.http.services.litellm.loadbalancer.server.port=4000"
    depends_on:
      - ollama
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:4000/health"]
      interval: 30s
      timeout: 10s
      retries: 5

  # === Application Layer ===
  dify-api:
    image: langgenius/dify-api:latest
    container_name: dify-api
    restart: unless-stopped
    environment:
      MODE: api
      SECRET_KEY: "{{ vault_pg_dify_password | hash('sha256') }}"
      DB_USERNAME: dify
      DB_PASSWORD: "{{ vault_pg_dify_password }}"
      DB_HOST: "10.10.30.3"
      DB_PORT: "{{ pgbouncer_port }}"
      DB_DATABASE: dify
      REDIS_HOST: "10.10.30.3"
      REDIS_PORT: "{{ dragonflydb_port }}"
      REDIS_PASSWORD: "{{ vault_dragonflydb_password }}"
      VECTOR_STORE: pgvector
      PGVECTOR_HOST: "10.10.30.3"
      PGVECTOR_PORT: "{{ postgresql_port }}"
      PGVECTOR_USER: dify
      PGVECTOR_PASSWORD: "{{ vault_pg_dify_password }}"
      PGVECTOR_DATABASE: dify
    volumes:
      - /opt/ai-stack/dify/storage:/app/api/storage
    networks:
      - frontend
      - backend
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5001/health"]
      interval: 30s
      timeout: 10s
      retries: 5

  dify-web:
    image: langgenius/dify-web:latest
    container_name: dify-web
    restart: unless-stopped
    environment:
      CONSOLE_API_URL: "https://dify.{{ domain }}"
      APP_API_URL: "https://dify.{{ domain }}"
    networks:
      - frontend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.dify.rule=Host(`dify.{{ domain }}`)"
      - "traefik.http.services.dify.loadbalancer.server.port=3000"
    depends_on:
      - dify-api

  n8n:
    image: docker.n8n.io/n8nio/n8n:latest
    container_name: n8n
    restart: unless-stopped
    environment:
      DB_TYPE: postgresdb
      DB_POSTGRESDB_HOST: "10.10.30.3"
      DB_POSTGRESDB_PORT: "{{ pgbouncer_port }}"
      DB_POSTGRESDB_DATABASE: n8n
      DB_POSTGRESDB_USER: n8n
      DB_POSTGRESDB_PASSWORD: "{{ vault_pg_n8n_password }}"
      EXECUTIONS_DATA_SAVE_ON_ERROR: all
      EXECUTIONS_DATA_SAVE_ON_SUCCESS: none
      N8N_DIAGNOSTICS_ENABLED: "false"
      N8N_PERSONALIZATION_ENABLED: "false"
      WEBHOOK_URL: "https://n8n.{{ domain }}"
      GENERIC_TIMEZONE: "{{ timezone }}"
    volumes:
      - /opt/ai-stack/n8n:/home/node/.n8n
    networks:
      - frontend
      - backend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.n8n.rule=Host(`n8n.{{ domain }}`)"
      - "traefik.http.services.n8n.loadbalancer.server.port=5678"
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:5678/healthz"]
      interval: 30s
      timeout: 10s
      retries: 5

  lobechat:
    image: lobehub/lobe-chat:latest
    container_name: lobechat
    restart: unless-stopped
    environment:
      OPENAI_API_KEY: "sk-litellm"
      OPENAI_PROXY_URL: "http://litellm:4000/v1"
      ACCESS_CODE: "{{ vault_pg_lobechat_password | hash('md5') | truncate(12, true, '') }}"
    networks:
      - frontend
      - backend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.lobechat.rule=Host(`chat.{{ domain }}`)"
      - "traefik.http.services.lobechat.loadbalancer.server.port=3210"
    depends_on:
      - litellm

  ruflo:
    image: ghcr.io/ruvnet/ruflo:latest
    container_name: ruflo
    restart: unless-stopped
    environment:
      DATABASE_URL: "postgresql://agentdb:{{ vault_pg_agentdb_password }}@10.10.30.3:{{ pgbouncer_port }}/agentdb"
      REDIS_URL: "redis://:{{ vault_dragonflydb_password }}@10.10.30.3:{{ dragonflydb_port }}"
      LLM_API_URL: "http://litellm:4000/v1"
      LLM_API_KEY: "sk-litellm"
    networks:
      - frontend
      - backend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.ruflo.rule=Host(`ruflo.{{ domain }}`)"
      - "traefik.http.services.ruflo.loadbalancer.server.port=3000"
    depends_on:
      - litellm

  # === AGENTIC STACK ===
  paperclip:
    image: ghcr.io/paperclipai/paperclip:latest
    container_name: paperclip
    restart: unless-stopped
    environment:
      DATABASE_URL: "postgresql://paperclip:{{ vault_pg_paperclip_password }}@10.10.30.3:{{ pgbouncer_port }}/paperclip"
      PORT: "3100"
      SERVICE_UI: "true"
      BETTER_AUTH_SECRET: "{{ vault_paperclip_auth_secret }}"
      PAPERCLIP_DEPLOYMENT_MODE: "authenticated"
      PAPERCLIP_DEPLOYMENT_EXPOSURE: "private"
      PAPERCLIP_PUBLIC_URL: "https://paperclip.{{ domain }}"
      PAPERCLIP_HOME: /paperclip
      PAPERCLIP_TELEMETRY_DISABLED: "1"
      ANTHROPIC_API_KEY: "{{ vault_anthropic_api_key }}"
      OPENAI_API_KEY: "{{ vault_openai_api_key }}"
    volumes:
      - /opt/ai-stack/paperclip:/paperclip
    networks:
      - frontend
      - backend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.paperclip.rule=Host(`paperclip.{{ domain }}`)"
      - "traefik.http.services.paperclip.loadbalancer.server.port=3100"
    deploy:
      resources:
        limits:
          memory: 2G
    healthcheck:
      test: ["CMD", "curl", "-f", "http://localhost:3100/api/health"]
      interval: 30s
      timeout: 10s
      retries: 5

  hermes:
    build:
      context: /opt/ai-stack/hermes
      dockerfile: Dockerfile
    image: hermes-agent:latest
    container_name: hermes
    restart: unless-stopped
    environment:
      HERMES_HOME: /opt/data
      # LLM — route through LiteLLM
      OPENAI_API_KEY: "sk-litellm"
      OPENAI_PROXY_URL: "http://litellm:4000/v1"
      # Direct API keys for fallback
      ANTHROPIC_API_KEY: "{{ vault_anthropic_api_key }}"
      # API Server
      API_SERVER_ENABLED: "true"
      API_SERVER_KEY: "{{ vault_hermes_api_key }}"
      API_SERVER_PORT: "3400"
      # Gateway — Telegram (per-employee bots)
      TELEGRAM_BOT_TOKEN: "{{ vault_telegram_bot_piotr }}"
      # Session management
      SESSION_IDLE_MINUTES: "1440"
      SESSION_RESET_HOUR: "4"
    volumes:
      - /opt/ai-stack/hermes-data:/opt/data
    networks:
      - frontend
      - backend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.hermes.rule=Host(`hermes.{{ domain }}`)"
      - "traefik.http.services.hermes.loadbalancer.server.port=3400"
    depends_on:
      - litellm
    deploy:
      resources:
        limits:
          memory: 2G

  # === BUSINESS APPLICATIONS ===
  borys:
    image: node:20-slim
    container_name: borys
    restart: unless-stopped
    working_dir: /app
    command: ["npm", "start"]
    environment:
      NODE_ENV: production
      DATABASE_URL: "postgresql://borys:{{ vault_pg_borys_password }}@10.10.30.3:{{ pgbouncer_port }}/borys"
      REDIS_URL: "redis://:{{ vault_dragonflydb_password }}@10.10.30.3:{{ dragonflydb_port }}"
      NEXTAUTH_URL: "https://borys.{{ domain }}"
      NEXTAUTH_SECRET: "{{ vault_pg_borys_password | hash('sha256') }}"
      LLM_API_URL: "http://litellm:4000/v1"
      LLM_API_KEY: "sk-litellm"
    volumes:
      - /opt/ai-stack/borys:/app
    ports:
      - "3300:3000"
    networks:
      - frontend
      - backend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.borys.rule=Host(`borys.{{ domain }}`)"
      - "traefik.http.services.borys.loadbalancer.server.port=3000"

  rekrutacja:
    image: node:20-slim
    container_name: rekrutacja
    restart: unless-stopped
    working_dir: /app
    command: ["npm", "start"]
    environment:
      NODE_ENV: production
      DATABASE_URL: "postgresql://rekrutacja:{{ vault_pg_rekrutacja_password }}@10.10.30.3:{{ pgbouncer_port }}/rekrutacja"
      REDIS_URL: "redis://:{{ vault_dragonflydb_password }}@10.10.30.3:{{ dragonflydb_port }}"
      NEXTAUTH_URL: "https://rekrutacja.{{ domain }}"
      NEXTAUTH_SECRET: "{{ vault_pg_rekrutacja_password | hash('sha256') }}"
    volumes:
      - /opt/ai-stack/rekrutacja:/app
    ports:
      - "3200:3000"
    networks:
      - frontend
      - backend
    labels:
      - "traefik.enable=true"
      - "traefik.http.routers.rekrutacja.rule=Host(`rekrutacja.{{ domain }}`)"
      - "traefik.http.services.rekrutacja.loadbalancer.server.port=3000"

  # === CLOUDFLARE COMPANION (auto-DNS) ===
  cloudflare-companion:
    image: tiredofit/traefik-cloudflare-companion:latest
    container_name: cloudflare-companion
    restart: unless-stopped
    environment:
      CF_TOKEN: "{{ vault_cloudflare_api_token }}"
      TARGET_DOMAIN: "{{ vault_cloudflare_tunnel_id }}.cfargotunnel.com"
      DOMAIN1: "{{ domain }}"
      DOMAIN1_ZONE_ID: "{{ vault_cloudflare_zone_id }}"
      DOMAIN1_PROXIED: "true"
      TRAEFIK_VERSION: 3
    volumes:
      - /var/run/docker.sock:/var/run/docker.sock:ro

networks:
  frontend:
    external: true
  backend:
    external: true
